# SignalRoom environment — copy to .env.local, fill in, and mirror into
# Vercel project env. See docs/INTEGRATIONS.md for how to obtain each value.

# ---- Supabase (required first) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server only — never expose to the client

# ---- Auth (Supabase) — see docs/AUTH.md ----
# Setting NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY above flips the
# app from open DEMO mode to enforced Supabase Auth (middleware redirects to
# /login). Email+password is the primary method and is on by default in Supabase.
# SSO feature flags — set to "true" to SHOW that sign-in button on /login. The
# provider itself (client id/secret, SAML metadata) is configured in the Supabase
# dashboard (Auth → Providers / Auth → SSO), not here.
NEXT_PUBLIC_AUTH_GOOGLE=             # =true to show "Continue with Google" (OAuth)
NEXT_PUBLIC_AUTH_GITHUB=             # =true to show "Continue with GitHub" (OAuth)
NEXT_PUBLIC_AUTH_AZURE=              # =true to show "Continue with Microsoft" (OAuth)
NEXT_PUBLIC_AUTH_SAML=               # =true to show SAML/OIDC SSO (sign in by email domain)
NEXT_PUBLIC_AUTH_PASSKEY=            # =true to show passkey (WebAuthn) sign-in; enable Passkeys in the Supabase dashboard first

# ---- Anthropic (enrichment / briefings / alerts / responses) ----
ANTHROPIC_API_KEY=

# ---- Ingest sources (spec §4) ----
# These are platform-level fallbacks. A campaign may override any SURVEYING key
# (kwatch/newsdata/gnews/apify/meta_ad_library/firecrawl/podcastindex) with its
# own via campaign_integrations — see docs/INTEGRATIONS.md § Per-client credentials.
KWATCH_API_KEY=                       # config push from S6
INGEST_KEY_KWATCH=                    # x-ingest-key shared secret per source
NEWSDATA_API_KEY=
GNEWS_API_KEY=                        # fallback only
APIFY_TOKEN=
INGEST_KEY_APIFY=
INGEST_KEY_BLUESKY=
INGEST_KEY_RSS=
INGEST_KEY_MANUAL=                    # S2 "+ Add missed article"
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=
OPENAI_API_KEY=                       # Whisper transcription (F4)

# ---- Delivery ----
RESEND_API_KEY=
CELLCAST_API_KEY=                     # urgent SMS only (Phase 3)

# ---- Response rails (Phase 4) ----
ZERNIO_API_TOKEN=
META_AD_LIBRARY_TOKEN=                # F1 opponent ads

# ---- S11 Organic Reach ----
FIRECRAWL_API_KEY=
AIRTABLE_TOKEN=                       # optional: sync the runbook base
AIRTABLE_BASE_ID=

# ---- Billing (Phase 3) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Observability (optional) ----
SENTRY_DSN=
