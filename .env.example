# SignalRoom environment — copy to .env.local, fill in, and mirror into
# Vercel project env. See docs/INTEGRATIONS.md for how to obtain each value.

# ---- Supabase (required first) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server only — never expose to the client

# ---- Anthropic (enrichment / briefings / alerts / responses) ----
ANTHROPIC_API_KEY=

# ---- Ingest sources (spec §4) ----
KWATCH_API_KEY=                       # config push from S6
INGEST_KEY_KWATCH=                    # x-ingest-key shared secret per source
NEWSDATA_API_KEY=
GNEWS_API_KEY=                        # fallback only
APIFY_TOKEN=
INGEST_KEY_APIFY=
INGEST_KEY_BLUESKY=
INGEST_KEY_RSS=
INGEST_KEY_MANUAL=                    # S2 "+ Add missed article"
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=
OPENAI_API_KEY=                       # Whisper transcription (F4)

# ---- Delivery ----
RESEND_API_KEY=
CELLCAST_API_KEY=                     # urgent SMS only (Phase 3)

# ---- Response rails (Phase 4) ----
ZERNIO_API_TOKEN=
META_AD_LIBRARY_TOKEN=                # F1 opponent ads

# ---- S11 Organic Reach ----
FIRECRAWL_API_KEY=
AIRTABLE_TOKEN=                       # optional: sync the runbook base
AIRTABLE_BASE_ID=

# ---- Billing (Phase 3) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Observability (optional) ----
SENTRY_DSN=
